  "GOON_VERIFY_RUNS": "3",
  "GOON_DAEMON_AUTO_START": "true",
  "GOON_WORKSPACE_DIR": "",

  "_comment_autonomy": "How much goon does without asking. Defaults keep every gate ON.",
