{
  "_comment": "Copy to config.json and fill what you need. Empty string = unset (uses default). Secrets live here in plain text — keep config.json out of git (.gitignore already covers it).",

  "GOON_LLM_PROVIDER": "openai",

  "OPENAI_API_KEY": "sk-...",
  "OPENAI_MODEL": "gpt-4o-mini",
