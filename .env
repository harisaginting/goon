# --- LLM provider ---
# Default provider: "openai" (chat completions). Use "mock" for offline tests.
GOON_LLM_PROVIDER=mock

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (optional, used when GOON_LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# --- Confluence ---
# Used by the "confluence" tool. Atlassian Cloud uses email + API token.
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_EMAIL=you@example.com
CONFLUENCE_API_TOKEN=

# --- Telegram ---
# Used by the "telegram" tool to send notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Override base URL for local testing or self-hosted bot proxies.
TELEGRAM_API_BASE_URL=

# --- Agent tuning ---
GOON_MAX_STEPS=5
GOON_TIMEOUT_SECONDS=20
GOON_MEMORY_PATH=
