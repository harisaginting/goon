# ============================================================================
# goon — environment variables
# ============================================================================
# Copy this file to `.env` (in your project), or move it to
# ~/.config/goon/.env to share across projects.
#
# Required vs optional:
#   1. LLM PROVIDER         — required for everything (or use mock for offline)
#   2. AUTONOMOUS DAEMON    — required for `goon start` (board + git host)
#   3. TELEGRAM BOT         — optional, lets you drive goon from your phone
#   4. CONFLUENCE TOOL      — optional, lets the agent read your wiki
#   5. STORAGE / TUNING     — almost everyone leaves these on defaults
#
# After filling in, verify with:   `goon doctor`
# ============================================================================


# ============================================================================
# 1. LLM PROVIDER  (pick ONE — required)
# ============================================================================
# openai | anthropic | ollama | mock
GOON_LLM_PROVIDER=openai

# --- Option A: OpenAI (easiest, paid) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Option B: Anthropic (paid) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# --- Option C: Ollama (free, local, no API key) ---
# Install from ollama.com, then:
#   ollama serve
#   ollama pull qwen2.5-coder:7b      (or llama3 / mistral / ...)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Option D: Mock (offline, returns canned replies — for tests) ---
# GOON_LLM_PROVIDER=mock
# GOON_MOCK_REPLIES='{"tool":"finish","args":{"message":"hi"}}'


# ============================================================================
# 2. AUTONOMOUS DAEMON  (required only for `goon start`)
# ============================================================================
# Pick where tickets come from and where PRs go. Leave both empty to use
# goon as a one-shot CLI agent only.

# Board: where tickets come from
GOON_BOARD=                       # jira | github | mock

# Git host: where PRs / MRs are opened (and reviewed via Telegram)
GOON_GIT_HOST=                    # github | gitlab | bitbucket | mock

# Skip the user-approval gates and run fully unattended.
# Default: gates fire (recommended) — you approve via `goon train`,
# the web UI, or Telegram.
GOON_AUTO_APPROVE=                # 1 | true | yes  (any other value = off)

# How often to poll the board (seconds).
GOON_POLL_SECONDS=300

# How many extra "verify" passes after execute, before opening the PR.
GOON_VERIFY_RUNS=3

# Map a board project key to a local clone path. Use "*" for default.
# Example: "ENG=/home/me/repos/eng,WEB=/home/me/repos/web,*=/home/me/repos/default"
GOON_REPO_MAP=


# --- Atlassian Cloud  (Jira board + Confluence tool share these creds) ---
# Set these THREE and Jira+Confluence both work without further config.
# Per-product overrides below win when set (useful for self-hosted splits).
ATLASSIAN_BASE_URL=https://your-domain.atlassian.net
ATLASSIAN_EMAIL=you@example.com
ATLASSIAN_API_TOKEN=              # id.atlassian.com/manage-profile/security/api-tokens

# --- Jira board overrides  (when GOON_BOARD=jira) ---
# Leave empty to inherit from ATLASSIAN_* above.
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_JQL=                         # default: assignee=currentUser() AND statusCategory!=Done


# --- GitHub  (board source AND/OR PR host) ---
GITHUB_TOKEN=                     # repo + issues + pull_requests scopes
GITHUB_REPOS=                     # comma-separated "owner/repo,owner/repo"
GITHUB_LABEL=                     # filter to issues with this label (optional)
GITHUB_ASSIGNEE=@me               # filter to assignee (default @me)
GITHUB_API_URL=                   # override for GitHub Enterprise


# --- GitLab MR host  (when GOON_GIT_HOST=gitlab) ---
GITLAB_TOKEN=
GITLAB_API_URL=                   # default https://gitlab.com/api/v4


# --- Bitbucket Cloud PR host  (when GOON_GIT_HOST=bitbucket) ---
# Use EITHER a workspace/repo access token, OR an Atlassian email + app
# password. Bitbucket auth is SEPARATE from your Atlassian API token —
# generate an app password at:
#   https://bitbucket.org/account/settings/app-passwords
# Bitbucket Server (self-hosted) is not supported — different REST API.
BITBUCKET_TOKEN=
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=
BITBUCKET_API_URL=                # default https://api.bitbucket.org/2.0


# ============================================================================
# 3. TELEGRAM BOT  (optional — inbound bot you can DM from your phone)
# ============================================================================
# When BOTH the bot token AND the secret are set, `goon start` spins up an
# inbound bot you can drive with /status, /run, /prs, /review, etc.
# Without GOON_TELEGRAM_SECRET the bot is disabled (outbound notifications
# still work as long as the token is set).

TELEGRAM_BOT_TOKEN=               # from @BotFather on Telegram
GOON_TELEGRAM_SECRET=             # any random string — users prove they know it via /auth <secret>

# Default chat for outbound notifications (workflow done, etc.). Optional.
TELEGRAM_CHAT_ID=

# Default repos when the user types `/prs` with no arguments.
# Comma-separated. Example: "harisaginting/goon,you/other-repo"
GOON_REVIEW_REPOS=

# Override base URL — only for self-hosted bot proxies / testing.
TELEGRAM_API_BASE_URL=


# ============================================================================
# 4. CONFLUENCE TOOL  (optional — lets the agent read your wiki)
# ============================================================================
# Leave empty to inherit from ATLASSIAN_* above (BASE_URL gets "/wiki"
# auto-appended for the standard Cloud layout).
CONFLUENCE_BASE_URL=
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=


# ============================================================================
# 5. STORAGE / LOGGING / TUNING  (defaults are usually fine)
# ============================================================================
# All runtime files live under one directory — by default ./storage/
# relative to the working directory, so each project gets self-contained
# state you can `.gitignore`.
#
# Layout:
#   $GOON_STORAGE_DIR/logs/goon.log     rotated structured log
#   $GOON_STORAGE_DIR/memory.json       passive runtime state
#   $GOON_STORAGE_DIR/memory/           active markdown notes (PINNED.md, ...)
#   $GOON_STORAGE_DIR/goon.pid          present while daemon runs

GOON_STORAGE_DIR=                 # default: ./storage
GOON_MEMORY_PATH=                 # default: $GOON_STORAGE_DIR/memory.json
GOON_MEMORY_DIR=                  # default: $GOON_STORAGE_DIR/memory
GOON_PID_FILE=                    # default: $GOON_STORAGE_DIR/goon.pid

# Workflow file (per-phase hooks + PR templates). Browse with `goon workflow show`.
GOON_WORKFLOW_FILE=               # default: ./workflow.json

# Logging — every prompt, tool call, HTTP request, workflow phase.
GOON_LOG_FILE=                    # default: $GOON_STORAGE_DIR/logs/goon.log
GOON_LOG_LEVEL=info               # debug | info | warn | error
GOON_LOG_FORMAT=text              # text (human-readable) | json (jq-friendly)

# Agent loop bounds.
GOON_MAX_STEPS=5                  # max tool calls per agent run (1..50)
GOON_TIMEOUT_SECONDS=20           # per-step timeout
