# --- LLM provider ---
# Default provider: "openai" (chat completions).
# Other options: "anthropic", "ollama" (local models), "mock" (offline tests).
GOON_LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (optional, used when GOON_LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Ollama — local models, no API key needed (used when GOON_LLM_PROVIDER=ollama)
# Make sure `ollama serve` is running and the model is pulled:
#   ollama pull llama3       # or qwen2.5-coder, mistral, etc.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Atlassian Cloud (shared between Jira + Confluence) ---
# Both products live under the same Atlassian Account, so the email and API
# token are the same for Jira AND Confluence. Set these three and the
# per-product vars below default to them — Confluence's URL even gets "/wiki"
# auto-appended. Override per product only if your install splits them.
ATLASSIAN_BASE_URL=https://your-domain.atlassian.net
ATLASSIAN_EMAIL=you@example.com
ATLASSIAN_API_TOKEN=         # https://id.atlassian.com/manage-profile/security/api-tokens

# --- Confluence (per-product overrides) ---
# Optional. Used by the "confluence" tool. Leave empty to inherit from the
# ATLASSIAN_* vars above (CONFLUENCE_BASE_URL gets ATLASSIAN_BASE_URL/wiki).
CONFLUENCE_BASE_URL=
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=

# --- Telegram ---
# Used by the "telegram" tool to send notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Override base URL for local testing or self-hosted bot proxies.
TELEGRAM_API_BASE_URL=

# --- Agent tuning ---
GOON_MAX_STEPS=5
GOON_TIMEOUT_SECONDS=20
GOON_MEMORY_PATH=

# --- Logging ---
# Where every prompt, tool call, HTTP request, and workflow phase gets
# written. Rotates at 10 MB, keeps 3 rotations. Browse via `goon logs`.
GOON_LOG_FILE=             # default: ~/.goon/logs/goon.log
GOON_LOG_LEVEL=info        # debug | info | warn | error
GOON_LOG_FORMAT=text       # text (human-readable) | json (jq-friendly)

# --- Autonomous daemon (`goon start`) ---
# Pick a board to poll: jira | github | mock
GOON_BOARD=
# Pick a git host for PR/MR creation: github | gitlab | bitbucket | mock
GOON_GIT_HOST=
# Poll the board this often (seconds). Default 300 = 5 minutes.
GOON_POLL_SECONDS=300
# How many extra "verify" passes the agent runs before opening a PR.
GOON_VERIFY_RUNS=3
# Map a board project key to a local clone path. Use "*" for default.
# Example: "ENG=/home/me/repos/eng,WEB=/home/me/repos/web,*=/home/me/repos/default"
GOON_REPO_MAP=
GOON_PID_FILE=
# Override the location of workflow.json (per-phase hooks + PR templates).
# Default search order: ./goon/workflow.json → $XDG_CONFIG_HOME/goon/workflow.json
# → ~/.config/goon/workflow.json → ~/.goon/workflow.json
# See `goon workflow hooks` for available hook names + env vars.
GOON_WORKFLOW_FILE=

# --- Jira board (when GOON_BOARD=jira; per-product overrides) ---
# Leave the first three empty to inherit from the ATLASSIAN_* vars above.
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
# JQL filter. Defaults to: assignee=currentUser() AND statusCategory!=Done
JIRA_JQL=

# --- GitHub Issues board / PR host ---
GITHUB_TOKEN=
GITHUB_REPOS=                 # comma-separated "owner/repo,owner/repo"
GITHUB_LABEL=                 # filter to issues with this label (optional)
GITHUB_ASSIGNEE=@me           # filter to assignee
GITHUB_API_URL=               # override for GitHub Enterprise

# --- GitLab MR host ---
GITLAB_TOKEN=
GITLAB_API_URL=               # override for self-hosted GitLab

# --- Bitbucket Cloud PR host (when GOON_GIT_HOST=bitbucket) ---
# Provide either BITBUCKET_TOKEN (workspace/repo access token), or
# BITBUCKET_USERNAME + BITBUCKET_APP_PASSWORD. Token wins if both set.
# Bitbucket Server (self-hosted) is not supported — different REST API.
BITBUCKET_TOKEN=
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=
BITBUCKET_API_URL=            # default https://api.bitbucket.org/2.0
